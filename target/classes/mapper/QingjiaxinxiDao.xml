<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yb.dao.QingjiaxinxiDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.yb.entity.QingjiaxinxiEntity" id="qingjiaxinxiMap">
        <result property="kechengmingcheng" column="kechengmingcheng"/>
        <result property="kechengleixing" column="kechengleixing"/>
        <result property="jiaoshizhanghao" column="jiaoshizhanghao"/>
        <result property="jiaoshixingming" column="jiaoshixingming"/>
        <result property="banji" column="banji"/>
        <result property="shenqingshijian" column="shenqingshijian"/>
        <result property="xueshengzhanghao" column="xueshengzhanghao"/>
        <result property="xueshengxingming" column="xueshengxingming"/>
        <result property="qingjialeixing" column="qingjialeixing"/>
        <result property="kaishishijian" column="kaishishijian"/>
        <result property="jieshushijian" column="jieshushijian"/>
        <result property="zhengmingcailiao" column="zhengmingcailiao"/>
        <result property="jutishiyou" column="jutishiyou"/>
        <result property="sfsh" column="sfsh"/>
        <result property="shhf" column="shhf"/>
    </resultMap>

	<select id="selectListVO"
		resultType="com.yb.entity.vo.QingjiaxinxiVO" >
		SELECT * FROM qingjiaxinxi  qingjiaxinxi         
        <where>${ew.sqlSegment}</where>
	</select>
	
	<select id="selectVO"
		resultType="com.yb.entity.vo.QingjiaxinxiVO" >
		SELECT  qingjiaxinxi.* FROM qingjiaxinxi  qingjiaxinxi 	
 		<where>${ew.sqlSegment}</where>
	</select>

    <select id="selectListView"
		resultType="com.yb.entity.view.QingjiaxinxiView" >

		SELECT  qingjiaxinxi.* FROM qingjiaxinxi  qingjiaxinxi 	        
        <where>${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.yb.entity.view.QingjiaxinxiView" >
		SELECT * FROM qingjiaxinxi  qingjiaxinxi <where>${ew.sqlSegment}</where>
	</select>
	

    <select id="selectValue" resultType="map" >
        SELECT ${params.xColumn},
        IFNULL(
        <choose>
            <when test="params.method == '总和'">sum(${params.yColumn})</when>
            <when test="params.method == '总数'">count(${params.yColumn})</when>
            <when test="params.method == '最大'">max(${params.yColumn})</when>
            <when test="params.method == '最小'">min(${params.yColumn})</when>
            <when test="params.method == '平均'">ROUND(avg(${params.yColumn}), 2)</when>
            <otherwise>sum(${params.yColumn})</otherwise>
        </choose>
        ,
        0) total FROM qingjiaxinxi
        <where>${ew.sqlSegment}</where>
        group by ${params.xColumn}
    </select>

    <select id="selectTimeStatValue" resultType="map" >
        <if test = 'params.timeStatType == "日"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y-%m-%d') ${params.xColumn},
                IFNULL(
                <choose>
                    <when test="params.method == '总和'">sum(${params.yColumn})</when>
                    <when test="params.method == '总数'">count(${params.yColumn})</when>
                    <when test="params.method == '最大'">max(${params.yColumn})</when>
                    <when test="params.method == '最小'">min(${params.yColumn})</when>
                    <when test="params.method == '平均'">ROUND(avg(${params.yColumn}), 2)</when>
                    <otherwise>sum(${params.yColumn})</otherwise>
                </choose>
                ,
                0) total FROM qingjiaxinxi
                <where>${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y-%m-%d')
        </if>
        <if test='params.timeStatType == "周"'>
                -- 1、按年和周数值分组
                -- 2、先按年降序，再按周降序
                SELECT CONCAT(YEAR(${params.xColumn}), '年 第', WEEK(${params.xColumn}, 1), '周') AS ${params.xColumn},
                IFNULL(
                <choose>
                    <when test="params.method == '总和'">sum(${params.yColumn})</when>
                    <when test="params.method == '总数'">count(${params.yColumn})</when>
                    <when test="params.method == '最大'">max(${params.yColumn})</when>
                    <when test="params.method == '最小'">min(${params.yColumn})</when>
                    <when test="params.method == '平均'">ROUND(avg(${params.yColumn}), 2)</when>
                    <otherwise>sum(${params.yColumn})</otherwise>
                </choose>
                ,
                0) total FROM qingjiaxinxi
                <where>${ew.sqlSegment}</where>
                GROUP BY YEAR(${params.xColumn}), WEEK(${params.xColumn}, 1)
                ORDER BY YEAR(${params.xColumn}) DESC, WEEK(${params.xColumn}, 1) DESC
        </if>
        <if test = 'params.timeStatType == "月"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y-%m') ${params.xColumn},
                IFNULL(
                <choose>
                    <when test="params.method == '总和'">sum(${params.yColumn})</when>
                    <when test="params.method == '总数'">count(${params.yColumn})</when>
                    <when test="params.method == '最大'">max(${params.yColumn})</when>
                    <when test="params.method == '最小'">min(${params.yColumn})</when>
                    <when test="params.method == '平均'">ROUND(avg(${params.yColumn}), 2)</when>
                    <otherwise>sum(${params.yColumn})</otherwise>
                </choose>
                ,
                0) total FROM qingjiaxinxi
                <where>${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y-%m')
        </if>
        <if test='params.timeStatType == "季"'>
                SELECT CONCAT(YEAR(${params.xColumn}), ' - ', ELT(QUARTER(${params.xColumn}), '第一季度', '第二季度', '第三季度', '第四季度')) as ${params.xColumn},
                IFNULL(
                <choose>
                    <when test="params.method == '总和'">sum(${params.yColumn})</when>
                    <when test="params.method == '总数'">count(${params.yColumn})</when>
                    <when test="params.method == '最大'">max(${params.yColumn})</when>
                    <when test="params.method == '最小'">min(${params.yColumn})</when>
                    <when test="params.method == '平均'">ROUND(avg(${params.yColumn}), 2)</when>
                    <otherwise>sum(${params.yColumn})</otherwise>
                </choose>
                ,
                0) total FROM qingjiaxinxi
                <where>${ew.sqlSegment}</where>
                group by CONCAT(YEAR(${params.xColumn}), ' - ', ELT(QUARTER(${params.xColumn}), '第一季度', '第二季度', '第三季度', '第四季度'))
        </if>
        <if test = 'params.timeStatType == "年"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y') ${params.xColumn},
                IFNULL(
                <choose>
                    <when test="params.method == '总和'">sum(${params.yColumn})</when>
                    <when test="params.method == '总数'">count(${params.yColumn})</when>
                    <when test="params.method == '最大'">max(${params.yColumn})</when>
                    <when test="params.method == '最小'">min(${params.yColumn})</when>
                    <when test="params.method == '平均'">ROUND(avg(${params.yColumn}), 2)</when>
                    <otherwise>sum(${params.yColumn})</otherwise>
                </choose>
                ,
                0) total FROM qingjiaxinxi
                <where>${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y')
        </if>
    </select>

    <select id="selectGroup" resultType="map" >
        SELECT ${params.column} , count(1) total FROM qingjiaxinxi
        <where>${ew.sqlSegment}</where>
        group by ${params.column}
    </select>




</mapper>
