<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yb.dao.JiaoshiDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.yb.entity.JiaoshiEntity" id="jiaoshiMap">
        <result property="jiaoshizhanghao" column="jiaoshizhanghao"/>
        <result property="mima" column="mima"/>
        <result property="jiaoshixingming" column="jiaoshixingming"/>
        <result property="xingbie" column="xingbie"/>
        <result property="lianxifangshi" column="lianxifangshi"/>
        <result property="touxiang" column="touxiang"/>
        <result property="banji" column="banji"/>
    </resultMap>

	<select id="selectListVO"
		resultType="com.yb.entity.vo.JiaoshiVO" >
		SELECT * FROM jiaoshi  jiaoshi         
        <where>${ew.sqlSegment}</where>
	</select>
	
	<select id="selectVO"
		resultType="com.yb.entity.vo.JiaoshiVO" >
		SELECT  jiaoshi.* FROM jiaoshi  jiaoshi 	
 		<where>${ew.sqlSegment}</where>
	</select>

    <select id="selectListView"
		resultType="com.yb.entity.view.JiaoshiView" >

		SELECT  jiaoshi.* FROM jiaoshi  jiaoshi 	        
        <where>${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.yb.entity.view.JiaoshiView" >
		SELECT * FROM jiaoshi  jiaoshi <where>${ew.sqlSegment}</where>
	</select>
	


</mapper>
